# Proteger archivos sensibles
<FilesMatch "\.(env|sql|md|log|lock|phar)$">
    Require all denied
</FilesMatch>

# Proteger directorios internos
RedirectMatch 403 ^/src/.*$
RedirectMatch 403 ^/config/(?!database\.php$).*$
RedirectMatch 403 ^/tools/.*$
RedirectMatch 403 ^/lib/(?!.*\.php$).*$
RedirectMatch 403 ^/vendor/.*$

# Desactivar listado de directorios
Options -Indexes

# Seguridad de sesión
<IfModule php_module>
    php_flag session.cookie_httponly on
    php_flag session.cookie_secure off
    php_value session.cookie_samesite "Lax"
</IfModule>

# UTF-8
AddDefaultCharset UTF-8

# Cache de assets
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>
