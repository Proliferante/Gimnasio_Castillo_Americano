{
    "name": "gca/sistema-academico",
    "description": "Sistema Académico - Gimnasio Castillo Americano",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "config/env.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"echo '[OK] Autoload generado.' . PHP_EOL;\""
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
